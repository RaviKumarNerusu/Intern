# ================================
# SERVER CONFIGURATION
# ================================
PORT=5000
NODE_ENV=development
SERVER_PUBLIC_URL=http://localhost:5000
SERVE_FRONTEND=false

# ================================
# DATABASE (MongoDB)
# ================================
# Local example:
# mongodb://127.0.0.1:27017/finance_dashboard
# Production example:
# mongodb+srv://<username>:<password>@cluster.mongodb.net/finance_dashboard

MONGO_URI=mongodb://127.0.0.1:27017/finance_dashboard
MONGO_MAX_RETRIES=5
MONGO_RETRY_DELAY_MS=3000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# ================================
# AUTHENTICATION (JWT)
# ================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1d

# Refresh token (optional but recommended)
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# DEFAULT ADMIN USER
# ================================
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=System Administrator
ADMIN_PASSWORD=your_admin_password_here

# ================================
# FRONTEND & CORS
# ================================
FRONTEND_URL=http://localhost:3000

# Comma-separated list for multiple origins
# Example:
# http://localhost:3000,https://your-frontend.vercel.app

CORS_ALLOWED_ORIGINS=http://localhost:3000

# ================================
# OPTIONAL FEATURES
# ================================
ENABLE_LOGGING=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
